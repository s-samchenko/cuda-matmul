{
  "name": "CUDA Development",
  "image": "nvidia/cuda:12.2.0-devel-ubuntu22.04",
  "customizations": {
    "vscode": {
      "extensions": [
        "nvidia.nsight-vscode-edition",
        "ms-vscode.cpptools",
        "twxs.cmake",
        "ms-vscode.cmake-tools"
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get install -y cmake build-essential"
}